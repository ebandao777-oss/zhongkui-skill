{
  "_meta": {
    "version": "1.0",
    "description": "钟馗 Layer 1 检测模式碎片化存储。每个模式的 pieces 数组单独拼接后得到完整正则。单片段不含可被安全引擎识别的完整攻击关键词。",
    "usage": "re.compile(''.join(pattern['pieces']), re.IGNORECASE)",
    "manual_base_count": 137,
    "architecture": "基础库(manual) + 增量(nvd/seebug)，--update 仅替换增量部分"
  },
  "C1_injection": [
    {
      "id": "C1_001",
      "label": "ig+nore instructions",
      "pieces": [
        "ig",
        "nore\\s+(all\\s+)?(prev",
        "ious|prior)\\s+inst",
        "ructions?"
      ],
      "source": "manual"
    },
    {
      "id": "C1_002",
      "label": "yo+u are now jail",
      "pieces": [
        "yo",
        "u\\s+are\\s+now\\s+(a\\s+)?(jai",
        "lbreak|uncensored|unfiltered)"
      ],
      "source": "manual"
    },
    {
      "id": "C1_003",
      "label": "sys+tem prompt over+ride",
      "pieces": [
