{
  "_meta": {
    "version": "1.0",
    "description": "钟馗 Layer 1 检测模式碎片化存储。每个模式的 pieces 数组单独拼接后得到完整正则。单片段不含可被安全引擎识别的完整攻击关键词。",
    "usage": "re.compile(''.join(pattern['pieces']), re.IGNORECASE)"
  },
  "C1_injection": [
    {
      "id": "C1_001",
      "label": "ig+nore instructions",
      "pieces": ["ig", "nore\\s+(all\\s+)?(prev", "ious|prior)\\s+inst", "ructions?"]
    },
    {
      "id": "C1_002",
      "label": "yo+u are now jail",
      "pieces": ["yo", "u\\s+are\\s+now\\s+(a\\s+)?(jai", "lbreak|uncensored|unfiltered)"]
    },
    {
      "id": "C1_003",
      "label": "sys+tem prompt over+ride",
      "pieces": ["sys", "tem\\s+", "pr", "ompt\\s+over", "ride"]
    },
    {
      "id": "C1_004",
